{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (Clang)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Clang)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-tests",
      "displayName": "Debug with Tests (Clang)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "{{PROJECT_NAME}}_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release-tests",
      "displayName": "Release with Tests (Clang)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "{{PROJECT_NAME}}_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "debug-tests",
      "configurePreset": "debug-tests"
    },
    {
      "name": "release-tests",
      "configurePreset": "release-tests"
    }
  ],
  "testPresets": [
    {
      "name": "debug-tests",
      "configurePreset": "debug-tests",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-tests",
      "configurePreset": "release-tests",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
